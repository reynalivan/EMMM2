{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EMMM",
  "version": "0.1.0",
  "identifier": "com.reynalivan.emmm",
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/reynalivan/EMMM/releases/latest/download/latest.json"],
      "pubkey": "REPLACE_WITH_ED25519_PUBLIC_KEY"
    }
  },
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "EMMM",
        "url": "index.html",
        "width": 1280,
        "height": 800,
        "visible": false
      },
      {
        "label": "splashscreen",
        "title": "EMMM Loading",
        "url": "splash.html",
        "width": 600,
        "height": 400,
        "transparent": false,
        "decorations": false,
        "resizable": false,
        "center": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": { "resources/": "" }
  }
}
